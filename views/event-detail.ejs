<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="/sass/main.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-5">
    <a href="/calendar" class="btn btn-secondary mb-4">&larr; Back to Calendar</a>
    <div class="card">
      <div class="card-header">
        <h2><%= event.event_title %></h2>
      </div>
      <div class="card-body">
        <% if (event.menu_picture) { %>
          <img src="<%= event.menu_picture %>" alt="Event Image" class="img-fluid mb-3" style="max-width:300px;">
        <% } %>
        <p><strong>Description:</strong> <%= event.event_description %></p>
        <p><strong>Date:</strong> <%= event.event_date ? event.event_date.toISOString ? event.event_date.toISOString().slice(0,10) : event.event_date : '' %></p>
        <p><strong>Time:</strong> <%= event.event_start_time %> - <%= event.event_close_time %></p>
        <p><strong>Address:</strong> <%= event.event_address %></p>
        <% if (event.Lan && event.Log) { %>
          <p><strong>Location:</strong> Lat: <%= event.Lan %>, Lng: <%= event.Log %></p>
        <% } %>
        <p><strong>Created At:</strong> <%= event.createdAt ? event.createdAt.toISOString ? event.createdAt.toISOString().slice(0,19).replace('T',' ') : event.createdAt : '' %></p>
        <p><strong>Updated At:</strong> <%= event.updatedAt ? event.updatedAt.toISOString ? event.updatedAt.toISOString().slice(0,19).replace('T',' ') : event.updatedAt : '' %></p>
      </div>
    </div>
  </div>
</body>
</html> 
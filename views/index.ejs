                  <a href="javascript:;" class="dropdown-toggle-nocaret options dropdown-toggle"
                    data-bs-toggle="dropdown">
                    <span class="material-icons-outlined fs-5">more_vert</span>
                  </a>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:;">Action</a></li>
                    <li><a class="dropdown-item" href="javascript:;">Another action</a></li>
                    <li><a class="dropdown-item" href="javascript:;">Something else here</a></li>
                  </ul>
                </div>
               </div>
              <div class="d-flex flex-column gap-4">
                <% if (popularVendors && popularVendors.length > 0) { %>
                  <% popularVendors.forEach(function(vendor) { %>
                    <div class="d-flex align-items-center gap-3">
                      <img src="/images/avatars/01.png" width="48" class="rounded-3" alt="Vendor">
                      <div class="flex-grow-1">
                        <h6 class="mb-0 fw-bold"><%= vendor.business_name || 'Unnamed Business' %></h6>
                        <p class="mb-0 text-muted"><%= vendor.user ? vendor.user.username : 'Unknown User' %></p>
                      </div>
                      <div class="text-end">
                        <small class="text-muted"><%= new Date(vendor.createdAt).toLocaleDateString() %></small>
                      </div>
                    </div>
                  <% }); %>
                <% } else { %>
                  <p class="text-muted mb-0">No popular vendors</p>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div><!--end row-->

    </div>

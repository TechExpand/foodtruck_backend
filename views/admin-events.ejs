<!doctype html>
<html lang="en" data-bs-theme="light">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FTE Admin | Event Management</title>
  <!--favicon-->
	<link rel="icon" href="/images/truckmarkerBlue.png" type="image/png">

  <!--plugins-->
  <link href="plugins/perfect-scrollbar/css/perfect-scrollbar.css" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="plugins/metismenu/metisMenu.min.css">
  <link rel="stylesheet" type="text/css" href="plugins/metismenu/mm-vertical.css">
  <link rel="stylesheet" type="text/css" href="plugins/simplebar/css/simplebar.css">
  <!--bootstrap css-->
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Material+Icons+Outlined" rel="stylesheet">
  <!--main css-->
  <link href="/css/bootstrap-extended.css" rel="stylesheet">
  <link href="/sass/main.css" rel="stylesheet">
  <link href="/sass/dark-theme.css" rel="stylesheet">
  <link href="/sass/semi-dark.css" rel="stylesheet">
  <link href="/sass/bordered-theme.css" rel="stylesheet">
  <link href="/sass/responsive.css" rel="stylesheet">
  <!-- DataTables CSS -->
  <link href="plugins/datatable/css/dataTables.bootstrap5.min.css" rel="stylesheet">
</head>

<body>

  <!--start header-->
  <header class="top-header">
    <nav class="navbar navbar-expand align-items-center gap-4">
      <div class="btn-toggle">
        <a href="javascript:;"><i class="material-icons-outlined">menu</i></a>
      </div>
      <div class="search-bar flex-grow-1">
        <div class="position-relative">
          <input class="form-control rounded-5 px-5 search-control d-lg-block d-none" type="text" placeholder="Search events..." id="eventSearch">
          <span class="material-icons-outlined position-absolute d-lg-block d-none ms-3 translate-middle-y start-0 top-50">search</span>
        </div>
      </div>
      <ul class="navbar-nav gap-1 nav-right-links align-items-center">
        <li class="nav-item">
          <a class="nav-link" href="/admin-vendors"><i class="material-icons-outlined">people</i> Vendors</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin-tags"><i class="material-icons-outlined">local_offer</i> Tags</a>
        </li>
      </ul>
    </nav>
  </header>
  <!--end header-->

  <!--start sidebar-->
  <aside class="sidebar-wrapper" data-simplebar="true">
    <div class="sidebar-header">
      <div>
        <img src="/images/top-logo.png" class="logo-icon" alt="logo icon" width="120">
      </div>
      <div>
        <h4 class="logo-text">FTE Admin</h4>
      </div>
      <div class="toggle-icon ms-auto">
        <i class="material-icons-outlined">menu</i>
      </div>
    </div>
    <ul class="metismenu" id="menu">
      <li>
        <a href="/admin-vendors" class="has-arrow">
          <div class="parent-icon"><i class="material-icons-outlined">people</i></div>
          <div class="menu-title">Vendor Management</div>
        </a>
      </li>
      <li>
        <a href="/admin-tags" class="has-arrow">
          <div class="parent-icon"><i class="material-icons-outlined">local_offer</i></div>
          <div class="menu-title">Tag Management</div>
        </a>
      </li>
      <li>
        <a href="/admin-events" class="has-arrow">
          <div class="parent-icon"><i class="material-icons-outlined">event</i></div>
          <div class="menu-title">Event Management</div>
        </a>
      </li>
    </ul>
  </aside>
  <!--end sidebar-->

  <!--start page wrapper -->
  <div class="page-wrapper">
    <div class="page-content">
      <!--breadcrumb-->
      <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="breadcrumb-title pe-3">Event Management</div>
        <div class="ps-3">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
              <li class="breadcrumb-item"><a href="javascript:;"><i class="material-icons-outlined">home</i></a></li>
              <li class="breadcrumb-item active" aria-current="page">Events</li>
            </ol>
          </nav>
        </div>
      </div>
      <!--end breadcrumb-->

      <div class="card">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div>
              <h5 class="mb-0">Event List</h5>
              <p class="mb-0 text-secondary">Manage events and assign vendors</p>
            </div>
            <div class="ms-auto">
              <button class="btn btn-primary" onclick="refreshEvents()">
                <i class="material-icons-outlined">refresh</i> Refresh
              </button>
            </div>
          </div>
          <hr>
          <div class="table-responsive">
            <table id="eventsTable" class="table table-striped table-bordered">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Event Title</th>
                  <th>Date</th>
                  <th>Time</th>
                  <th>Address</th>
                  <th>Vendors</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="eventsTableBody">
                <!-- Events will be loaded here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--end page wrapper -->

  <!-- Event Details Modal -->
  <div class="modal fade" id="eventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Event Details</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="eventModalBody">
          <!-- Event details will be loaded here -->
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Vendor to Event Modal -->
  <div class="modal fade" id="addVendorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Add Vendor to Event</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label for="vendorSelect" class="form-label">Select Vendor</label>
            <select class="form-select" id="vendorSelect">
              <option value="">Choose a vendor...</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" onclick="addVendorToEvent()">Add Vendor</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <!--plugins-->
  <script src="plugins/perfect-scrollbar/js/perfect-scrollbar.js"></script>
  <script src="plugins/metismenu/metisMenu.min.js"></script>
  <script src="plugins/simplebar/js/simplebar.min.js"></script>
  <!-- DataTables JS -->
  <script src="plugins/datatable/js/jquery.dataTables.min.js"></script>
  <script src="plugins/datatable/js/dataTables.bootstrap5.min.js"></script>

  <script>
    let currentEventId = null;
    let eventsTable;

    // Initialize DataTable
    $(document).ready(function() {
      eventsTable = $('#eventsTable').DataTable({
        pageLength: 25,
        order: [[0, 'desc']]
      });
      
      loadEvents();
      loadVendors();
    });

    // Load all events
    async function loadEvents() {
      try {
        const response = await fetch('/admin/events');
        const data = await response.json();
        
        if (data.success) {
          displayEvents(data.data);
        } else {
          alert('Error loading events: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error loading events');
      }
    }

    // Display events in table
    function displayEvents(events) {
      const tbody = document.getElementById('eventsTableBody');
      tbody.innerHTML = '';

      events.forEach(event => {
        const eventDate = new Date(event.event_date);
        const vendorCount = event.featured ? event.featured.length : 0;
        
        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${event.id}</td>
          <td>
            <div>
              <h6 class="mb-0">${event.event_title || 'N/A'}</h6>
              <small class="text-muted">${event.event_description || 'N/A'}</small>
            </div>
          </td>
          <td>${eventDate.toLocaleDateString()}</td>
          <td>${event.event_start_time} - ${event.event_close_time}</td>
          <td>${event.event_address || 'N/A'}</td>
          <td>
            <span class="badge bg-info">${vendorCount} vendors</span>
          </td>
          <td>
            <div class="btn-group" role="group">
              <button class="btn btn-sm btn-outline-primary" onclick="viewEvent(${event.id})">
                <i class="material-icons-outlined">visibility</i>
              </button>
              <button class="btn btn-sm btn-outline-success" onclick="addVendor(${event.id})">
                <i class="material-icons-outlined">add</i>
              </button>
            </div>
          </td>
        `;
        tbody.appendChild(row);
      });

      // Refresh DataTable
      if (eventsTable) {
        eventsTable.destroy();
      }
      eventsTable = $('#eventsTable').DataTable({
        pageLength: 25,
        order: [[0, 'desc']]
      });
    }

    // Load vendors for assignment
    async function loadVendors() {
      try {
        const response = await fetch('/admin/vendors');
        const data = await response.json();
        
        if (data.success) {
          const vendorSelect = document.getElementById('vendorSelect');
          vendorSelect.innerHTML = '<option value="">Choose a vendor...</option>';
          
          data.data.forEach(vendor => {
            const option = document.createElement('option');
            option.value = vendor.id;
            option.textContent = `${vendor.business_name || 'N/A'} (${vendor.user?.email || 'N/A'})`;
            vendorSelect.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading vendors:', error);
      }
    }

    // View event details
    async function viewEvent(eventId) {
      try {
        const response = await fetch(`/admin/events/${eventId}`);
        const data = await response.json();
        
        if (data.success) {
          const event = data.data;
          const modalBody = document.getElementById('eventModalBody');
          
          const eventDate = new Date(event.event_date);
          const vendors = event.featured || [];
          
          modalBody.innerHTML = `
            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <label class="form-label fw-bold">Event Title</label>
                  <p class="mb-0">${event.event_title || 'N/A'}</p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Description</label>
                  <p class="mb-0">${event.event_description || 'N/A'}</p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Date</label>
                  <p class="mb-0">${eventDate.toLocaleDateString()}</p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Time</label>
                  <p class="mb-0">${event.event_start_time} - ${event.event_close_time}</p>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3">
                  <label class="form-label fw-bold">Address</label>
                  <p class="mb-0">${event.event_address || 'N/A'}</p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Coordinates</label>
                  <p class="mb-0">Lat: ${event.Lan || 'N/A'}, Long: ${event.Log || 'N/A'}</p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Assigned Vendors (${vendors.length})</label>
                  <div class="list-group">
                    ${vendors.length > 0 ? vendors.map(vendor => `
                      <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                          <h6 class="mb-0">${vendor.profile.business_name || 'N/A'}</h6>
                          <small class="text-muted">${vendor.profile.user?.email || 'N/A'}</small>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" onclick="removeVendorFromEvent(${event.id}, ${vendor.profile.id})">
                          <i class="material-icons-outlined">remove</i>
                        </button>
                      </div>
                    `).join('') : '<p class="text-muted">No vendors assigned</p>'}
                  </div>
                </div>
              </div>
            </div>
          `;
          
          new bootstrap.Modal(document.getElementById('eventModal')).show();
        } else {
          alert('Error loading event details: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error loading event details');
      }
    }

    // Add vendor to event
    function addVendor(eventId) {
      currentEventId = eventId;
      new bootstrap.Modal(document.getElementById('addVendorModal')).show();
    }

    // Add vendor to event
    async function addVendorToEvent() {
      const profileId = document.getElementById('vendorSelect').value;
      
      if (!profileId) {
        alert('Please select a vendor');
        return;
      }

      try {
        const response = await fetch('/admin/events/add-vendor', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            eventId: currentEventId,
            profileId: profileId
          })
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Vendor added to event successfully');
          bootstrap.Modal.getInstance(document.getElementById('addVendorModal')).hide();
          loadEvents();
        } else {
          alert('Error adding vendor to event: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error adding vendor to event');
      }
    }

    // Remove vendor from event
    async function removeVendorFromEvent(eventId, profileId) {
      if (!confirm('Are you sure you want to remove this vendor from the event?')) {
        return;
      }

      try {
        const response = await fetch(`/admin/events/${eventId}/vendors/${profileId}`, {
          method: 'DELETE'
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Vendor removed from event successfully');
          viewEvent(eventId); // Refresh the modal
          loadEvents(); // Refresh the table
        } else {
          alert('Error removing vendor from event: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error removing vendor from event');
      }
    }

    // Search events
    document.getElementById('eventSearch').addEventListener('input', function(e) {
      const query = e.target.value;
      
      if (query.length > 2) {
        // For now, we'll just filter the existing table
        // In a real implementation, you'd want to add a search endpoint
        $('#eventsTable').DataTable().search(query).draw();
      } else if (query.length === 0) {
        $('#eventsTable').DataTable().search('').draw();
      }
    });

    // Refresh events
    function refreshEvents() {
      loadEvents();
    }
  </script>

</body>

</html> 
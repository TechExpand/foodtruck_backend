<!doctype html>
<html lang="en" data-bs-theme="light">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FTE Admin | Vendor Management</title>
  <!--favicon-->
	<link rel="icon" href="images/truckmarkerBlue.png" type="image/png">

  <!--plugins-->
  <link href="plugins/perfect-scrollbar/css/perfect-scrollbar.css" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="plugins/metismenu/metisMenu.min.css">
  <link rel="stylesheet" type="text/css" href="plugins/metismenu/mm-vertical.css">
  <link rel="stylesheet" type="text/css" href="plugins/simplebar/css/simplebar.css">
  <!--bootstrap css-->
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Material+Icons+Outlined" rel="stylesheet">
  <!--main css-->
  <link href="/css/bootstrap-extended.css" rel="stylesheet">
  <link href="/sass/main.css" rel="stylesheet">
  <link href="/sass/dark-theme.css" rel="stylesheet">
  <link href="/sass/semi-dark.css" rel="stylesheet">
  <link href="/sass/bordered-theme.css" rel="stylesheet">
  <link href="/sass/responsive.css" rel="stylesheet">
  <!-- DataTables CSS -->
  <link href="plugins/datatable/css/dataTables.bootstrap5.min.css" rel="stylesheet">
</head>

<body>

  <!--start header-->
  <header class="top-header">
    <nav class="navbar navbar-expand align-items-center gap-4">
      <div class="btn-toggle">
        <a href="javascript:;"><i class="material-icons-outlined">menu</i></a>
      </div>
      <div class="search-bar flex-grow-1">
        <div class="position-relative">
          <input class="form-control rounded-5 px-5 search-control d-lg-block d-none" type="text" placeholder="Search vendors..." id="vendorSearch">
          <span class="material-icons-outlined position-absolute d-lg-block d-none ms-3 translate-middle-y start-0 top-50">search</span>
        </div>
      </div>
      <ul class="navbar-nav gap-1 nav-right-links align-items-center">
        <li class="nav-item">
          <a class="nav-link" href="/admin-tags"><i class="material-icons-outlined">local_offer</i> Tags</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin-events"><i class="material-icons-outlined">event</i> Events</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin-promo-codes"><i class="material-icons-outlined">confirmation_number</i> Promo Codes</a>
        </li>
      </ul>
    </nav>
  </header>
  <!--end header-->

  <!--start sidebar-->
  <aside class="sidebar-wrapper" data-simplebar="true">
    <div class="sidebar-header">
      <div>
        <img src="/images/top-logo.png" class="logo-icon" alt="logo icon" width="120">
      </div>
      <div>
        <h4 class="logo-text">FTE Admin</h4>
      </div>
      <div class="toggle-icon ms-auto">
        <i class="material-icons-outlined">menu</i>
      </div>
    </div>
    <ul class="metismenu" id="menu">
      <li>
        <a href="/admin-vendors" class="has-arrow">
          <div class="parent-icon"><i class="material-icons-outlined">people</i></div>
          <div class="menu-title">Vendor Management</div>
        </a>
      </li>
      <li>
        <a href="/admin-tags" class="has-arrow">
          <div class="parent-icon"><i class="material-icons-outlined">local_offer</i></div>
          <div class="menu-title">Tag Management</div>
        </a>
      </li>
      <li>
        <a href="/admin-events" class="has-arrow">
          <div class="parent-icon"><i class="material-icons-outlined">event</i></div>
          <div class="menu-title">Event Management</div>
        </a>
      </li>
      <li>
        <a href="/admin-promo-codes" class="has-arrow">
          <div class="parent-icon"><i class="material-icons-outlined">confirmation_number</i></div>
          <div class="menu-title">Promo Codes</div>
        </a>
      </li>
    </ul>
  </aside>
  <!--end sidebar-->

  <!--start page wrapper -->
  <div class="page-wrapper">
    <div class="page-content">
      <!--breadcrumb-->
      <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="breadcrumb-title pe-3">Vendor Management</div>
        <div class="ps-3">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
              <li class="breadcrumb-item"><a href="javascript:;"><i class="material-icons-outlined">home</i></a></li>
              <li class="breadcrumb-item active" aria-current="page">Vendors</li>
            </ol>
          </nav>
        </div>
      </div>
      <!--end breadcrumb-->

      <div class="card">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div>
              <h5 class="mb-0">Vendor List</h5>
              <p class="mb-0 text-secondary">Manage all food truck vendors</p>
            </div>
            <div class="ms-auto">
              <button class="btn btn-primary" onclick="refreshVendors()">
                <i class="material-icons-outlined">refresh</i> Refresh
              </button>
            </div>
          </div>
          <hr>
          <div class="table-responsive">
            <table id="vendorsTable" class="table table-striped table-bordered">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Business Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Specialized Tag</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="vendorsTableBody">
                <!-- Vendors will be loaded here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--end page wrapper -->

  <!-- Vendor Details Modal -->
  <div class="modal fade" id="vendorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Vendor Details</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="vendorModalBody">
          <!-- Vendor details will be loaded here -->
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          <button type="button" class="btn btn-primary" onclick="saveVendorChanges()">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Tag Assignment Modal -->
  <div class="modal fade" id="tagModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Assign Homepage Tag</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label for="tagSelect" class="form-label">Select Tag</label>
            <select class="form-select" id="tagSelect">
              <option value="">Choose a tag...</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" onclick="assignTagToVendor()">Assign Tag</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <!--plugins-->
  <script src="plugins/perfect-scrollbar/js/perfect-scrollbar.js"></script>
  <script src="plugins/metismenu/metisMenu.min.js"></script>
  <script src="plugins/simplebar/js/simplebar.min.js"></script>
  <!-- DataTables JS -->
  <script src="plugins/datatable/js/jquery.dataTables.min.js"></script>
  <script src="plugins/datatable/js/dataTables.bootstrap5.min.js"></script>

  <script>
    let currentVendorId = null;
    let vendorsTable;

    // Initialize DataTable
    $(document).ready(function() {
      vendorsTable = $('#vendorsTable').DataTable({
        pageLength: 25,
        order: [[0, 'desc']]
      });
      
      loadVendors();
      loadTags();
    });

    // Load all vendors
    async function loadVendors() {
      try {
        const response = await fetch('/admin/vendors');
        const data = await response.json();
        
        if (data.success) {
          displayVendors(data.data);
        } else {
          alert('Error loading vendors: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error loading vendors');
      }
    }

    // Display vendors in table
    function displayVendors(vendors) {
      const tbody = document.getElementById('vendorsTableBody');
      tbody.innerHTML = '';

      vendors.forEach(vendor => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${vendor.id}</td>
          <td>
            <div class="d-flex align-items-center">
              <img src="${vendor.pro_pic || '/images/avatars/01.png'}" class="rounded-circle me-2" width="40" height="40" alt="">
              <div>
                <h6 class="mb-0">${vendor.business_name || 'N/A'}</h6>
                <small class="text-muted">${vendor.unique_detail || 'N/A'}</small>
              </div>
            </div>
          </td>
          <td>${vendor.user?.email || 'N/A'}</td>
          <td>${vendor.phone || 'N/A'}</td>
          <td>
            <span class="badge bg-primary">${vendor.specialTag?.tag?.title || 'No Tag'}</span>
          </td>
          <td>
            <div class="dropdown">
              <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                ...
              </button>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/admin/vendors/${vendor.id}/edit">Edit</a></li>
                <li><a class="dropdown-item text-danger" href="#" onclick="removeTag(${vendor.id}); return false;">Remove</a></li>
              </ul>
            </div>
          </td>
        `;
        tbody.appendChild(row);
      });

      // Refresh DataTable
      if (vendorsTable) {
        vendorsTable.destroy();
      }
      vendorsTable = $('#vendorsTable').DataTable({
        pageLength: 25,
        order: [[0, 'desc']]
      });
    }

    // Load tags for assignment
    async function loadTags() {
      try {
        const response = await fetch('/admin/tags');
        const data = await response.json();
        
        if (data.success) {
          const tagSelect = document.getElementById('tagSelect');
          tagSelect.innerHTML = '<option value="">Choose a tag...</option>';
          
          data.data.forEach(tag => {
            const option = document.createElement('option');
            option.value = tag.id;
            option.textContent = tag.title;
            tagSelect.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading tags:', error);
      }
    }

    // View vendor details
    async function viewVendor(vendorId) {
      try {
        const response = await fetch(`/admin/vendors/${vendorId}`);
        const data = await response.json();
        
        if (data.success) {
          const vendor = data.data;
          const modalBody = document.getElementById('vendorModalBody');
          
          modalBody.innerHTML = `
            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <label class="form-label">Business Name</label>
                  <input type="text" class="form-control" id="editBusinessName" value="${vendor.business_name || ''}">
                </div>
                <div class="mb-3">
                  <label class="form-label">Email</label>
                  <input type="email" class="form-control" value="${vendor.user?.email || ''}" readonly>
                </div>
                <div class="mb-3">
                  <label class="form-label">Phone</label>
                  <input type="text" class="form-control" id="editPhone" value="${vendor.phone || ''}">
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-3">
                  <label class="form-label">Unique Detail</label>
                  <input type="text" class="form-control" id="editUniqueDetail" value="${vendor.unique_detail || ''}">
                </div>
                <div class="mb-3">
                  <label class="form-label">Detail</label>
                  <textarea class="form-control" id="editDetail" rows="3">${vendor.detail || ''}</textarea>
                </div>
                <div class="mb-3">
                  <label class="form-label">Current Tag</label>
                  <input type="text" class="form-control" value="${vendor.specialTag?.tag?.title || 'No Tag'}" readonly>
                </div>
                <div class="mb-3">
                  <label class="form-label">Assign Special Tag</label>
                  <select class="form-select" id="editSpecialTagSelect">
                    <option value="">Choose a special tag...</option>
                  </select>
                </div>
              </div>
            </div>
          `;
          
          currentVendorId = vendorId;
          new bootstrap.Modal(document.getElementById('vendorModal')).show();

          const specialTagSelect = document.getElementById('editSpecialTagSelect');
          fetch('/admin/special-tags')
            .then(res => res.json())
            .then(data => {
              if (data.status && data.data) {
                data.data.forEach(tag => {
                  const option = document.createElement('option');
                  option.value = tag.id;
                  option.textContent = tag.tag ? tag.tag.title : `Tag #${tag.id}`;
                  if (vendor.specializedTagId === tag.id) option.selected = true;
                  specialTagSelect.appendChild(option);
                });
              }
            });
        } else {
          alert('Error loading vendor details: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error loading vendor details');
      }
    }

    // Save vendor changes
    async function saveVendorChanges() {
      if (!currentVendorId) return;

      const updateData = {
        business_name: document.getElementById('editBusinessName').value,
        phone: document.getElementById('editPhone').value,
        unique_detail: document.getElementById('editUniqueDetail').value,
        detail: document.getElementById('editDetail').value,
        specializedTagId: document.getElementById('editSpecialTagSelect').value || null
      };

      try {
        const response = await fetch(`/admin/vendors/${currentVendorId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(updateData)
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Vendor updated successfully');
          bootstrap.Modal.getInstance(document.getElementById('vendorModal')).hide();
          loadVendors();
        } else {
          alert('Error updating vendor: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error updating vendor');
      }
    }

    // Assign tag to vendor
    function assignTag(vendorId) {
      currentVendorId = vendorId;
      new bootstrap.Modal(document.getElementById('tagModal')).show();
    }

    // Assign tag to vendor
    async function assignTagToVendor() {
      const tagId = document.getElementById('tagSelect').value;
      
      if (!tagId) {
        alert('Please select a tag');
        return;
      }

      try {
        const response = await fetch('/admin/vendors/assign-tag', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            vendorId: currentVendorId,
            tagId: tagId
          })
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Tag assigned successfully');
          bootstrap.Modal.getInstance(document.getElementById('tagModal')).hide();
          loadVendors();
        } else {
          alert('Error assigning tag: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error assigning tag');
      }
    }

    // Remove tag from vendor
    async function removeTag(vendorId) {
      if (!confirm('Are you sure you want to remove the tag from this vendor?')) {
        return;
      }

      try {
        const response = await fetch(`/admin/vendors/${vendorId}/tag`, {
          method: 'DELETE'
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Tag removed successfully');
          loadVendors();
        } else {
          alert('Error removing tag: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error removing tag');
      }
    }

    // Search vendors
    document.getElementById('vendorSearch').addEventListener('input', function(e) {
      const query = e.target.value;
      
      if (query.length > 2) {
        searchVendors(query);
      } else if (query.length === 0) {
        loadVendors();
      }
    });

    async function searchVendors(query) {
      try {
        const response = await fetch(`/admin/vendors/search?query=${encodeURIComponent(query)}`);
        const data = await response.json();
        
        if (data.success) {
          displayVendors(data.data);
        }
      } catch (error) {
        console.error('Error searching vendors:', error);
      }
    }

    // Refresh vendors
    function refreshVendors() {
      loadVendors();
    }
  </script>

</body>

</html> 
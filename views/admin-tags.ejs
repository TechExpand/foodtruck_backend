  <!--start main wrapper-->
  <main class="main-wrapper">
    <div class="main-content">
      <!--breadcrumb-->
      <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="breadcrumb-title pe-3">FTE TAG TABLES</div>
        <div class="ps-3">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
              <li class="breadcrumb-item"><a href="javascript:;"><i class="bx bx-home-alt"></i></a>
              </li>
              <li class="breadcrumb-item active" aria-current="page">FoodTruck.Express</li>
            </ol>
          </nav>
        </div>
        <div class="ms-auto">
          <div class="btn-group">
            <button type="button" class="btn btn-primary">Settings</button>
            <button type="button" class="btn btn-primary split-bg-primary dropdown-toggle dropdown-toggle-split"
              data-bs-toggle="dropdown"> <span class="visually-hidden">Toggle Dropdown</span>
            </button>
            <div class="dropdown-menu dropdown-menu-right dropdown-menu-lg-end"> <a class="dropdown-item"
                href="javascript:;">Action</a>
              <a class="dropdown-item" href="javascript:;">Another action</a>
              <a class="dropdown-item" href="javascript:;">Something else here</a>
              <div class="dropdown-divider"></div> <a class="dropdown-item" href="javascript:;">Separated link</a>
            </div>
          </div>
        </div>
      </div>
      <!--end breadcrumb-->

      <div class="card">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div>
              <h5 class="mb-0">AllTag Table</h5>
              <p class="mb-0 text-secondary">All tags from the AllTag table</p>
            </div>
            <div class="ms-auto">
              <button class="btn btn-primary" onclick="showAddTagModal()">
                <i class="material-icons-outlined">add</i> Add New Tag
              </button>
              <button class="btn btn-secondary ms-2" onclick="refreshTags()">
                <i class="material-icons-outlined">refresh</i> Refresh
              </button>
            </div>
          </div>
          <hr>
          <div class="table-responsive">
            <table id="specialTagsTable" class="table table-striped table-bordered">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Title</th>
                  <th>Icon</th>
                  <th>Created At</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="specialTagsTableBody">
                <!-- Special Tags will be loaded here -->
                <% if (specialTags && specialTags.length > 0) { %>
                  <% specialTags.forEach(function(tag) { %>
                    <tr>
                      <td><%= tag.id %></td>
                      <td><span class="badge bg-primary fs-6"><%= tag.title %></span></td>
                      <td><%= tag.icon || 'N/A' %></td>
                      <td><%= new Date(tag.createdAt).toLocaleDateString() %></td>
                      <td>
                        <div class="btn-group" role="group">
                          <button class="btn btn-sm btn-outline-primary" data-title="<%= tag.title.replace(/"/g, '&quot;') %>" data-icon="<%= (tag.icon || '').replace(/"/g, '&quot;') %>" onclick="editTag(this, <%= tag.id %>)">
                            <i class="material-icons-outlined">edit</i>
                          </button>
                          <button class="btn btn-sm btn-outline-danger" onclick="deleteTag(<%= tag.id %>)">
                            <i class="material-icons-outlined">delete</i>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" class="text-center text-muted">No special tags found.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- All Tags Table -->
      <div class="card mt-4">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div>
              <h5 class="mb-0">Tag Table</h5>
              <p class="mb-0 text-secondary">All tags from the Tag table (excluding AllTag IDs)</p>
            </div>
            <div class="ms-auto">
              <button class="btn btn-secondary" onclick="refreshAllTags()">
                <i class="material-icons-outlined">refresh</i> Refresh
              </button>
            </div>
          </div>
          <hr>
          <div class="table-responsive">
            <table id="allTagsTable" class="table table-striped table-bordered">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Title</th>
                  <th>Icon</th>
                  <th>Created At</th>
                  <th>Type</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="allTagsTableBody">
                <!-- All Tags will be loaded here -->
                <% if (allTags && allTags.length > 0) { %>
                  <% allTags.forEach(function(tag) { %>
                    <tr>
                      <td><%= tag.id %></td>
                      <td><span class="badge bg-secondary fs-6"><%= tag.title %></span></td>
                      <td><%= tag.icon || 'N/A' %></td>
                      <td><%= new Date(tag.createdAt).toLocaleDateString() %></td>
                      <td>
                        <span class="badge bg-info">Tag Table</span>
                      </td>
                      <td>
                        <div class="btn-group" role="group">
                          <button class="btn btn-sm btn-outline-primary" data-title="<%= tag.title.replace(/"/g, '&quot;') %>" data-icon="<%= (tag.icon || '').replace(/"/g, '&quot;') %>" onclick="editTag(this, <%= tag.id %>)">
                            <i class="material-icons-outlined">edit</i>
                          </button>
                          <button class="btn btn-sm btn-outline-danger" onclick="deleteTag(<%= tag.id %>)">
                            <i class="material-icons-outlined">delete</i>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="6" class="text-center text-muted">No tags found.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
  <!--end main wrapper-->

  <!-- Add/Edit Tag Modal -->
  <div class="modal fade" id="tagModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="tagModalTitle">Add New Tag</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="tagForm">
            <div class="mb-3">
              <label for="tagTitle" class="form-label">Tag Title *</label>
              <input type="text" class="form-control" id="tagTitle" required>
            </div>
            <div class="mb-3">
              <label for="tagIcon" class="form-label">Icon (optional)</label>
              <input type="text" class="form-control" id="tagIcon" placeholder="e.g., restaurant, food, etc.">
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" onclick="saveTag()">Save Tag</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <!--plugins-->
  <script src="plugins/perfect-scrollbar/js/perfect-scrollbar.js"></script>
  <script src="plugins/metismenu/metisMenu.min.js"></script>
  <script src="plugins/simplebar/js/simplebar.min.js"></script>
  <!-- DataTables JS -->
  <script src="plugins/datatable/js/jquery.dataTables.min.js"></script>
  <script src="plugins/datatable/js/dataTables.bootstrap5.min.js"></script>

  <script>
    let currentTagId = null;
    let specialTagsTable;
    let allTagsTable;
    let isEditMode = false;

    // Initialize DataTables
    $(document).ready(function() {
      specialTagsTable = $('#specialTagsTable').DataTable({
        responsive: true,
        order: [[0, 'desc']],
        pageLength: 10,
        language: {
          search: "Search special tags:",
          lengthMenu: "Show _MENU_ special tags per page",
          info: "Showing _START_ to _END_ of _TOTAL_ special tags"
        }
      });

      allTagsTable = $('#allTagsTable').DataTable({
        responsive: true,
        order: [[0, 'desc']],
        pageLength: 15,
        language: {
          search: "Search all tags:",
          lengthMenu: "Show _MENU_ tags per page",
          info: "Showing _START_ to _END_ of _TOTAL_ tags"
        }
      });
    });

    // Show add tag modal
    function showAddTagModal() {
      isEditMode = false;
      currentTagId = null;
      document.getElementById('tagModalTitle').textContent = 'Add New Tag';
      document.getElementById('tagForm').reset();
      new bootstrap.Modal(document.getElementById('tagModal')).show();
    }

    // Edit tag
    function editTag(btn, tagId) {
      isEditMode = true;
      currentTagId = tagId;
      document.getElementById('tagModalTitle').textContent = 'Edit Tag';
      document.getElementById('tagTitle').value = btn.getAttribute('data-title');
      document.getElementById('tagIcon').value = btn.getAttribute('data-icon');
      new bootstrap.Modal(document.getElementById('tagModal')).show();
    }

    // Save tag (create or update)
    async function saveTag() {
      const title = document.getElementById('tagTitle').value.trim();
      const icon = document.getElementById('tagIcon').value.trim();

      if (!title) {
        alert('Tag title is required');
        return;
      }

      const tagData = { title, icon };

      try {
        const url = isEditMode ? `/admin/tags/${currentTagId}` : '/admin/tags';
        const method = isEditMode ? 'PUT' : 'POST';

        const response = await fetch(url, {
          method: method,
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(tagData)
        });

        const data = await response.json();
        
        if (data.success) {
          alert(isEditMode ? 'Tag updated successfully' : 'Tag created successfully');
          bootstrap.Modal.getInstance(document.getElementById('tagModal')).hide();
          location.reload(); // Reload page to refresh both tables
        } else {
          alert('Error saving tag: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error saving tag');
      }
    }

    // Delete tag
    async function deleteTag(tagId) {
      if (!confirm('Are you sure you want to delete this tag? This action cannot be undone.')) {
        return;
      }

      try {
        const response = await fetch(`/admin/tags/${tagId}`, {
          method: 'DELETE'
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Tag deleted successfully');
          location.reload(); // Reload page to refresh both tables
        } else {
          alert('Error deleting tag: ' + data.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error deleting tag');
      }
    }

    // Refresh special tags
    function refreshTags() {
      location.reload();
    }

    // Refresh all tags
    function refreshAllTags() {
      location.reload();
    }
  </script>

</body>

</html> 